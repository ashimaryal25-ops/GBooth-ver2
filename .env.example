OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- On-screen download QR: two modes, local wins if both are set ---
#
# MODE 1 (preferred): the booth serves the file off its own Wi-Fi hotspot, so
# guests' photos never leave this machine and nothing lands on a public URL.
# Prefer this at events where minors are present.
# Set to "auto" to detect the address (prefers 192.168.137.1, the Windows
# Mobile Hotspot address), or set it explicitly if auto picks the wrong NIC:
#   CARDIFYBOOTH_LOCAL_DOWNLOAD_BASE_URL=auto
#   CARDIFYBOOTH_LOCAL_DOWNLOAD_BASE_URL=http://192.168.137.1:3000
# Also required: Windows Mobile Hotspot turned on, and a firewall rule allowing
# inbound traffic to the app's port on the private network. Without that rule
# phones just hang with no error.
CARDIFYBOOTH_LOCAL_DOWNLOAD_BASE_URL=

# Hotspot details for the "join the Wi-Fi" QR shown as step 1 on the final
# screens. Leave the SSID blank to hide that step. NEXT_PUBLIC_ because the
# browser draws the QR; neither value is secret, both are shown to guests.
# Must match the hotspot Windows is actually broadcasting.
NEXT_PUBLIC_CARDIFYBOOTH_HOTSPOT_SSID=
NEXT_PUBLIC_CARDIFYBOOTH_HOTSPOT_PASSWORD=

# MODE 2 (fallback): upload to a public Vercel Blob store, for when phones
# cannot reach the booth directly. These URLs are publicly readable. The token
# stays on the booth server and is never sent to the browser.
# With neither mode configured, the kiosk shows "QR unavailable" and the rest
# of the booth keeps working.
BLOB_READ_WRITE_TOKEN=

# Optional. Leave blank to use the Windows default printer.
CARDIFYBOOTH_PRINTER_NAME=

# Optional local admin settings for future dashboard work.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- Printer low-roll email alert (scripts/check-printer-media.ps1) ---
# Gmail SMTP. SMTP_APP_PASSWORD must be a Google "App Password" (16 chars),
# NOT your normal account password. Generate one at:
#   Google Account > Security > 2-Step Verification > App passwords
SMTP_USER=
SMTP_APP_PASSWORD=
ALERT_EMAIL_TO=
# Optional overrides:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
CARDIFYBOOTH_LOW_THRESHOLD=50
CARDIFYBOOTH_ROLL_CAPACITY=700
# Folder containing DNP's cspstat.dll (installed by PrinterInfo). Default shown;
# only set if you installed PrinterInfo somewhere else.
CARDIFYBOOTH_DNP_DIR=C:\DNPPIA\PrinterInfo
# Testing only: force a fake remaining count. Leave blank for the real read.
CARDIFYBOOTH_SIMULATED_REMAINING=
